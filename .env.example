APP_ENV=development
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite:///./data/novel_generator.db
ARTIFACTS_DIR=./artifacts
OLLAMA_BASE_URL=http://127.0.0.1:11434
DEFAULT_MODEL=llama3.1:8b
MAX_CONCURRENT_RUNS=1
LOG_LEVEL=INFO
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_MAX_RETRIES=2
PROVIDER_CHAT_TIMEOUT_SECONDS=1800
PROVIDER_RETRY_BACKOFF_SECONDS=2
RUN_STALE_AFTER_SECONDS=3600
CHAPTER_SUMMARY_WINDOW=4
